# ================================================
# application.yml н…ңн”ҢлҰҝ
# мқҙ нҢҢмқјмқ„ application.ymlлЎң ліөмӮ¬н•ң нӣ„ passwordлҘј мҲҳм •н•ҳм„ёмҡ”.
# cp application.yml.example application.yml
# ================================================

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/driving_db?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
    username: root
    password: YOUR_PASSWORD_HERE   # вҶҗ ліёмқё MySQL л№„л°ҖлІҲнҳёлЎң ліҖкІҪ
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect
        jdbc:
          batch_size: 500
        order_inserts: true
        order_updates: true

server:
  port: 8080

logging:
  level:
    org.hibernate.SQL: DEBUG
