# ================================================
# application.yml 템플릿
# 로컬 실행: 이 파일을 application.yml로 복사 후 비밀번호 수정
#   cp application.yml.example application.yml
# Docker 실행: 환경변수로 자동 주입됨 (.env 사용)
# ================================================

spring:
  datasource:
    url: jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3306}/${DB_NAME:driving_db}?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:YOUR_PASSWORD_HERE}
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect
        jdbc:
          batch_size: 500
        order_inserts: true
        order_updates: true

server:
  port: ${SERVER_PORT:8080}

logging:
  level:
    org.hibernate.SQL: DEBUG

# 프론트엔드 origin (CORS 허용 목록)
frontend:
  cors-origins: ${FRONTEND_ORIGINS:http://localhost:5173,http://localhost:15173}

app:
  auth:
    jwt-secret: ${JWT_SECRET:dev-only-jwt-secret-please-replace-in-prod-min-32-chars-long}
    access-token-minutes: ${JWT_ACCESS_TOKEN_MINUTES:60}
    refresh-token-days: ${JWT_REFRESH_TOKEN_DAYS:14}
